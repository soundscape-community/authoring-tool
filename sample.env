#
# ======================================================================
# SECURITY WARNING: Review every value below before deploying to
# production. Default values are NOT safe for public-facing servers.
# ======================================================================

DJANGO_SETTINGS_MODULE=backend.settings.production

# SECURITY WARNING: Generate a unique random string (50+ chars).
# Example: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY='change-me'

# comma-separated list of hostnames that the server will accept
ALLOWED_HOSTS='authoring.soundscape.services'

# Comma-separated list of CSRF trusted origin URLs
CSRF_TRUSTED_ORIGINS='https://authoring.soundscape.services'

# user and group that the server runs as
PUID=1000
PGID=1000

# localhost port to listen on.
LOCALHOST_PORT=8000

# Set to true to show a global testing warning banner in the UI.
TESTING_WARNING_ENABLED=false

# Optional custom message for the testing warning banner.
TESTING_WARNING_MESSAGE='Testing environment — all changes will be lost.'

# directory for uploaded files
FILES_DIR=~/share.soundscape.services

# SECURITY WARNING: Change the database password to a strong random value.
# Postgresql settings
PSQL_DB_NAME=postgres
PSQL_DB_PASS=postgres
PSQL_DB_HOST=postgres
PSQL_DB_USER=postgres
PSQL_DB_PORT=5432


# Google OAuth credentials for social authentication. These should be set up in the Google Cloud Console:
# 1. Create a new project (or select an existing one).
# 2. Go to "APIs & Services" > "Credentials".
# 3. Click "Create Credentials" > "OAuth client ID".
# 4. Choose "Web application" and set the authorized redirect URI to:
#    https://your.domain.com/accounts/google/login/callback/
GOOGLE_OAUTH_CLIENT_ID=''
GOOGLE_OAUTH_CLIENT_SECRET=''